<%- include('./partials/header'); %>
    <body class="bg-gradient-to-b from-emerald-50 via-slate-50 to-gray-100 font-sans antialiased min-h-screen">
        <div class="max-w-5xl mx-auto px-4 py-4 space-y-6">
            <!-- Top bar -->
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <a href="/" class="text-gray-600 hover:text-gray-900"><i class="ri-arrow-left-line text-xl"></i></a>
                    <h1 class="text-xl font-bold tracking-tight text-gray-900">My Profile</h1>
                </div>
                <div class="flex items-center gap-3">
                    <a href="/users/logout"
                        class="hidden sm:inline-flex items-center gap-2 px-3 py-2 text-xs font-medium text-gray-600 bg-white border border-gray-200 rounded-full shadow-sm hover:bg-red-50 hover:text-red-600 hover:border-red-200 transition">
                        <i class="ri-logout-box-r-line text-base"></i>
                        <span>Logout</span>
                    </a>
                    <% if (typeof cartCount !== 'undefined' && cartCount > 0) { %>
                        <a href="/cart"
                            class="relative inline-flex items-center justify-center px-4 py-2 text-sm font-semibold text-white bg-emerald-600 rounded-full shadow-md hover:bg-emerald-700">
                            <i class="ri-shopping-cart-2-line mr-2 text-lg"></i>
                            Cart
                            <span class="ml-2 inline-flex items-center justify-center w-5 h-5 text-[11px] font-bold bg-white text-emerald-700 rounded-full">
                                <%= cartCount %>
                            </span>
                        </a>
                    <% } %>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <!-- Profile Details Sidebar -->
                <div class="md:col-span-1 space-y-4">
                    <div class="bg-white p-5 rounded-2xl shadow-sm border border-gray-100">
                        <div class="w-16 h-16 bg-emerald-100 text-emerald-700 rounded-full flex items-center justify-center text-2xl font-bold mb-4">
                            <%= user.name.charAt(0).toUpperCase() %>
                        </div>
                        <h2 class="text-lg font-bold text-gray-900"><%= user.name %></h2>
                        <p class="text-sm text-gray-500 mb-4"><%= user.email %></p>
                        <div class="border-t border-gray-100 pt-4 space-y-2">
                            <p class="text-sm flex items-center gap-2 text-gray-700">
                                <i class="ri-phone-line text-gray-400"></i> <%= user.phone || 'No phone added' %>
                            </p>
                        </div>
                    </div>

                    <div class="bg-white p-5 rounded-2xl shadow-sm border border-gray-100">
                        <h3 class="text-base font-bold text-gray-900 mb-3">Saved Addresses</h3>
                        <% if (user.addresses && user.addresses.length > 0) { %>
                            <div class="space-y-3">
                                <% user.addresses.forEach(addr => { %>
                                    <div class="p-3 border border-gray-100 rounded-xl bg-gray-50 relative group">
                                        <p class="text-xs font-semibold text-gray-700 mb-1"><%= addr.address %>, <%= addr.city %></p>
                                        <p class="text-[11px] text-gray-500 uppercase font-medium"><%= addr.state %> <%= addr.zip %></p>
                                        <p class="text-[11px] text-gray-600 font-semibold mt-1"><i class="ri-phone-line"></i> <%= addr.phone || 'N/A' %></p>
                                        
                                        <!-- Actions -->
                                        <div class="absolute top-3 right-3 flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                            <button type="button" onclick="document.getElementById('edit-form-<%= addr._id %>').classList.toggle('hidden')" class="text-blue-600 hover:text-blue-800 bg-blue-50 p-1.5 rounded-md"><i class="ri-edit-line"></i></button>
                                            <form action="/users/address/delete/<%= addr._id %>" method="POST" class="inline">
                                                <button type="submit" class="text-red-600 hover:text-red-800 bg-red-50 p-1.5 rounded-md"><i class="ri-delete-bin-line"></i></button>
                                            </form>
                                        </div>

                                        <!-- Edit Form -->
                                        <form id="edit-form-<%= addr._id %>" action="/users/address/edit/<%= addr._id %>" method="POST" class="hidden mt-3 pt-3 border-t border-gray-200">
                                            <div class="grid grid-cols-2 gap-2">
                                                <input type="text" name="address" value="<%= addr.address %>" placeholder="Street Address" class="col-span-2 text-xs rounded border border-gray-200 px-2 py-1.5 outline-none focus:border-emerald-500" required>
                                                <input type="text" name="city" value="<%= addr.city %>" placeholder="City" class="col-span-1 text-xs rounded border border-gray-200 px-2 py-1.5 outline-none focus:border-emerald-500" required>
                                                <input type="text" name="state" value="<%= addr.state %>" placeholder="State" class="col-span-1 text-xs rounded border border-gray-200 px-2 py-1.5 outline-none focus:border-emerald-500" required>
                                                <input type="text" name="zip" value="<%= addr.zip %>" placeholder="ZIP" class="col-span-1 text-xs rounded border border-gray-200 px-2 py-1.5 outline-none focus:border-emerald-500" required>
                                                <input type="text" name="phone" value="<%= addr.phone || '' %>" placeholder="Phone" class="col-span-1 text-xs rounded border border-gray-200 px-2 py-1.5 outline-none focus:border-emerald-500" required>
                                                <div class="col-span-2 flex gap-2 mt-1">
                                                    <button type="submit" class="flex-1 bg-emerald-600 text-white text-[11px] font-semibold py-1.5 rounded">Save Changes</button>
                                                    <button type="button" onclick="document.getElementById('edit-form-<%= addr._id %>').classList.add('hidden')" class="flex-1 bg-gray-200 text-gray-700 text-[11px] font-semibold py-1.5 rounded hover:bg-gray-300 transition">Cancel</button>
                                                </div>
                                            </div>
                                        </form>
                                    </div>
                                <% }) %>
                            </div>
                        <% } else { %>
                            <p class="text-sm text-gray-500">No addresses saved yet.</p>
                        <% } %>
                    </div>
                </div>

                <!-- Order History -->
                <div class="md:col-span-2 space-y-4">
                    <h2 class="text-lg font-bold text-gray-900 mb-2">Order History</h2>
                    <% if (orders && orders.length > 0) { %>
                        <div class="space-y-4">
                            <% orders.forEach(order => { %>
                                <div class="bg-white p-5 rounded-2xl shadow-sm border border-gray-100">
                                    <div class="flex flex-wrap justify-between items-start gap-4 mb-4 border-b border-gray-100 pb-4">
                                        <div>
                                            <p class="text-xs text-gray-500 uppercase tracking-wider font-semibold mb-1">Order #<%= order.orderID %></p>
                                            <p class="text-sm text-gray-900 font-medium"><%= new Date(order.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></p>
                                        </div>
                                        <div class="text-right flex flex-col items-end">
                                            <span class="inline-flex px-2 py-1 text-[11px] font-bold uppercase rounded-full <%= order.status === 'delivered' ? 'bg-emerald-100 text-emerald-800' : 'bg-blue-100 text-blue-800' %> mb-2">
                                                <%= order.status %>
                                            </span>
                                            <p class="text-lg font-bold text-gray-900">₹<%= order.totalPrice %></p>
                                        </div>
                                    </div>
                                    
                                    <div class="flex items-center gap-3 overflow-x-auto pb-2">
                                        <% order.products.forEach(item => { %>
                                            <% if (item.product) { %>
                                                <div class="flex-shrink-0 relative group">
                                                    <img src="/products/image/<%= item.product._id %>?v=1" class="w-16 h-16 rounded-lg object-cover border border-gray-200 bg-gray-50 p-1">
                                                    <span class="absolute -top-2 -right-2 w-5 h-5 bg-gray-900 text-white text-[10px] flex items-center justify-center rounded-full font-bold shadow-sm">
                                                        x<%= item.quantity %>
                                                    </span>
                                                </div>
                                            <% } %>
                                        <% }) %>
                                    </div>

                                    <div class="mt-4 pt-4 border-t border-gray-100 flex justify-between items-center">
                                        <a href="/order/details/<%= order.orderID %>" class="text-sm font-semibold text-emerald-600 hover:text-emerald-700">View Receipt</a>
                                        <form action="/cart/reorder/<%= order.orderID %>" method="POST">
                                            <button type="submit" class="px-5 py-2 bg-emerald-50 text-emerald-700 hover:bg-emerald-100 rounded-full text-sm font-bold transition flex items-center gap-2">
                                                <i class="ri-refresh-line"></i> Reorder
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                    <% } else { %>
                        <div class="bg-white p-10 rounded-2xl shadow-sm border border-gray-100 text-center flex flex-col items-center justify-center min-h-[300px]">
                            <div class="w-20 h-20 bg-gray-50 rounded-full flex items-center justify-center mb-4">
                                <i class="ri-shopping-bag-3-line text-4xl text-gray-300"></i>
                            </div>
                            <h3 class="text-lg font-bold text-gray-900">No orders yet</h3>
                            <p class="text-sm text-gray-500 mt-1 max-w-xs mx-auto">Looks like you haven't placed any orders. Start exploring our catalog to make your first purchase!</p>
                            <a href="/" class="inline-block mt-6 px-8 py-3 bg-emerald-600 text-white rounded-full font-semibold hover:bg-emerald-700 transition shadow-sm">Start Shopping</a>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </body>
<%- include('./partials/footer'); %>
