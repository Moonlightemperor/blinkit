<%- include('./partials/header'); %>

<body class="bg-gradient-to-b from-emerald-50 via-white to-gray-100 min-h-screen flex items-center justify-center px-4">
  <div class="w-full max-w-md">
    <div class="bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden">
      <div class="p-8 sm:p-10">
        <div class="flex items-start justify-between gap-4">
          <div>
            <h2 class="text-2xl font-bold text-gray-900">Admin Login</h2>
            <p class="mt-2 text-sm text-gray-600">Manage products and categories on Blinkit</p>
          </div>
          <div class="hidden sm:flex h-10 w-10 items-center justify-center rounded-xl bg-emerald-50 border border-emerald-100">
            <i class="ri-shield-user-line text-emerald-700 text-xl"></i>
          </div>
        </div>

        <form autocomplete="off" class="mt-8 space-y-5" action="/admin/login" method="POST">
          <div class="space-y-1">
            <label for="email" class="text-sm font-medium text-gray-700">Email</label>
            <input id="email" name="email" type="email" required
              class="w-full px-3 py-2.5 border border-gray-200 rounded-xl outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 text-sm"
              placeholder="admin@blink.com" />
          </div>

          <div class="space-y-1">
            <label for="password" class="text-sm font-medium text-gray-700">Password</label>
            <input id="password" name="password" type="password" required
              class="w-full px-3 py-2.5 border border-gray-200 rounded-xl outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 text-sm"
              placeholder="Your password" />
          </div>

          <div class="flex items-center justify-between pt-1">
            <a href="#" class="text-xs font-medium text-gray-600 hover:text-emerald-700 transition">
              Forgot password?
            </a>
          </div>

          <button type="submit"
            class="w-full mt-2 inline-flex justify-center items-center px-4 py-2.5 rounded-xl text-white font-semibold bg-emerald-600 hover:bg-emerald-700 transition shadow-sm">
            Sign in
          </button>
        </form>

        <p class="mt-6 text-center text-xs text-gray-500">
          Tip: set your admin credentials in the DB (default creation route uses `admin` password hash).
        </p>
      </div>
    </div>
  </div>
</body>

<%- include('./partials/footer'); %>