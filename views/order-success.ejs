<%- include('./partials/header'); %>

<body class="bg-gradient-to-b from-emerald-50 via-white to-gray-50 min-h-screen font-sans antialiased">
    <div class="max-w-lg mx-auto px-4 pt-8 pb-12">
        <div class="flex items-center justify-between mb-8">
            <a href="/" class="inline-flex items-center gap-2 text-gray-600 hover:text-emerald-700 transition">
                <i class="ri-arrow-left-s-line text-xl"></i>
                <span class="text-sm font-medium">Home</span>
            </a>
            <span class="text-xs font-medium text-emerald-700 bg-emerald-100 px-3 py-1 rounded-full">Paid</span>
        </div>

        <div class="text-center mb-10">
            <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-emerald-100 mb-6 shadow-inner ring-8 ring-emerald-50">
                <i class="ri-checkbox-circle-fill text-5xl text-emerald-600"></i>
            </div>
            <h1 class="text-2xl font-bold text-gray-900 tracking-tight">Payment successful</h1>
            <p class="mt-2 text-gray-600 text-sm leading-relaxed">
                Your order is confirmed. Thank you for shopping with Blinkit.
            </p>
        </div>

        <div class="bg-white rounded-2xl shadow-lg shadow-gray-200/80 border border-gray-100 overflow-hidden">
            <div class="bg-gradient-to-r from-emerald-600 to-teal-600 px-6 py-5 text-white">
                <p class="text-xs uppercase tracking-wider opacity-90 font-medium">Amount paid</p>
                <p class="text-3xl font-bold mt-1">
                    <%= payment.currency === 'INR' ? '₹' : payment.currency + ' ' %><%= Number(payment.amount).toFixed(2) %>
                </p>
            </div>
            <div class="px-6 py-5 space-y-4">
                <div class="flex justify-between gap-4 text-sm">
                    <span class="text-gray-500">Status</span>
                    <span class="font-semibold text-emerald-700 capitalize"><%= payment.status %></span>
                </div>
                <div class="border-t border-gray-100 pt-4">
                    <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Razorpay order ID</p>
                    <p class="text-sm font-mono text-gray-800 break-all"><%= payment.orderId %></p>
                </div>
                <div>
                    <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Payment ID</p>
                    <p class="text-sm font-mono text-gray-800 break-all"><%= payment.paymentId %></p>
                </div>
                <% if (payment.createdAt) { %>
                <div class="flex justify-between text-sm pt-2 border-t border-gray-100">
                    <span class="text-gray-500">Paid on</span>
                    <span class="text-gray-800"><%= new Date(payment.createdAt).toLocaleString('en-IN', { dateStyle: 'medium', timeStyle: 'short' }) %></span>
                </div>
                <% } %>
            </div>
        </div>

        <div class="mt-8 space-y-3">
            <a href="/"
                class="block w-full text-center bg-emerald-600 hover:bg-emerald-700 text-white font-semibold py-3.5 rounded-xl shadow-md shadow-emerald-600/25 transition">
                Continue shopping
            </a>
            <a href="/cart"
                class="block w-full text-center border border-gray-200 bg-white hover:bg-gray-50 text-gray-800 font-medium py-3 rounded-xl transition">
                View cart
            </a>
        </div>

        <p class="text-center text-xs text-gray-400 mt-10">
            A receipt has been recorded for your account. Keep this page for your records.
        </p>
    </div>
</body>

<%- include('./partials/footer'); %>
