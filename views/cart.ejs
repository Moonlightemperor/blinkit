<%- include('./partials/header'); %>

    <body class="bg-gray-100 font-sans antialiased">
        <div class="max-w-screen-md mx-auto p-4 space-y-4 pb-40">
            <!-- Header -->
            <div class="flex justify-between items-center py-4">
                <a href="/" class="text-lg text-gray-600 hover:text-gray-800"><i class="ri-arrow-left-s-line"></i></a>
                <h1 class="text-xl font-semibold">Checkout</h1>
                <a href="mailto:support@blinkit.com" class="text-sm text-emerald-700 font-medium hover:underline">Help</a>
            </div>

            <% if (cart && cart.length > 0) { %>
            <!-- Delivery Info -->
            <div class="bg-white p-4 rounded-2xl shadow-sm border border-gray-100">
                <div class="flex items-start gap-4">
                    <i
                        class="w-10 h-10 flex items-center justify-center rounded-full bg-emerald-50 text-emerald-600 text-2xl ri-timer-line"></i>
                    <div class="flex-1">
                        <p class="text-sm font-semibold text-gray-900">Delivery in
                            15 minutes</p>
                        <p class="text-xs text-gray-500 mt-0.5">Shipment of <%= cart.length %> item<%= cart.length > 1 ? 's' : '' %></p>
                    </div>
                </div>
                <div class="mt-4 space-y-3">
                    <% cart.forEach(elem=> { %>
                        <div
                            class="flex items-center gap-3 rounded-xl border border-gray-100 bg-gray-50 px-3 py-2.5">
                            <img src="/products/image/<%= elem.product._id %>?v=1"
                                alt="<%= elem.product.name %>" loading="lazy" decoding="async" class="w-14 h-14 rounded-lg object-cover">
                            <div class="flex-1">
                                <p class="text-sm font-medium text-gray-900 line-clamp-2">
                                    <%= elem.product.name %>
                                </p>
                                <p class="text-[11px] text-gray-400 mt-0.5">~ 1 unit</p>
                                <p class="text-sm font-semibold text-gray-900 mt-1">
                                    ₹<%= Number(elem.price)*Number(elem.quantity)%>
                                </p>
                            </div>
                            <div class="flex flex-col items-end gap-2">
                                <div class="flex items-center justify-center bg-emerald-50 text-emerald-700 rounded-full">
                                    <a href="/cart/remove/<%= elem.product._id %>"
                                        class="px-2 py-1 rounded-full hover:bg-emerald-100"><i
                                            class="ri-subtract-line text-sm"></i></a>
                                    <p class="mx-2 text-sm font-medium text-gray-900">
                                        <%= elem.quantity %>
                                    </p>
                                    <a href="/cart/add/<%= elem.product._id %>"
                                        class="px-2 py-1 rounded-full hover:bg-emerald-100"><i
                                            class="ri-add-line text-sm"></i></a>
                                </div>
                                <p class="text-[11px] text-gray-400 line-through">
                                    ₹<%= Number(elem.price)*Number(elem.quantity)+20 %>
                                </p>
                            </div>
                        </div>
                    <% })%>
                </div>
            </div>

            <!-- Before You Checkout -->
            <div class="bg-white p-4 rounded-2xl shadow-sm border border-gray-100">
                <div class="flex items-start justify-between gap-3">
                    <div>
                        <h2 class="text-lg font-semibold text-gray-900">Before you checkout</h2>
                        <p class="text-xs text-gray-500 mt-1">Recommended add-ons</p>
                    </div>
                    <span class="text-[11px] font-semibold text-emerald-700 bg-emerald-50 border border-emerald-100 px-3 py-1 rounded-full">
                        Quick picks
                    </span>
                </div>

                <div class="mt-4 grid grid-cols-2 sm:grid-cols-3 gap-3">
                    <% if(typeof rnproducts !== 'undefined') { %>
                        <% rnproducts.forEach(function(elem){ %>
                        <div class="bg-gray-50 border border-gray-100 rounded-2xl p-3 flex flex-col justify-between hover:border-emerald-200 transition group">
                            <div>
                                <div class="h-20 flex items-center justify-center bg-white rounded-xl border border-gray-100 overflow-hidden">
                                    <img src="/products/image/<%= elem._id %>?v=1"
                                        alt="<%= elem.name %>" class="h-20 w-auto object-contain">
                                </div>
                                <p class="text-[11px] text-gray-800 font-medium mt-2 line-clamp-2"><%= elem.name %></p>
                                <p class="text-[11px] text-gray-500 mt-1">1 unit</p>
                            </div>
                            <div class="mt-3 flex items-center justify-between gap-2">
                                <p class="text-sm font-bold text-gray-900">₹<%= elem.price %></p>
                                <a href="/cart/add/<%= elem._id %>" class="bg-emerald-50 text-emerald-700 group-hover:bg-emerald-600 group-hover:text-white text-[11px] font-bold px-3 py-1.5 rounded-full transition text-center">
                                    ADD
                                </a>
                            </div>
                        </div>
                        <% }) %>
                    <% } %>
                </div>
            </div>

            <!-- Delivery Address -->
            <div id="address-section" class="bg-white p-4 rounded-2xl shadow-sm border border-gray-100">
                <h3 class="text-base font-bold text-gray-900 mb-4">Delivery Address</h3>
                
                <% if (user.addresses && user.addresses.length > 0) { %>
                    <div class="space-y-3 mb-4">
                        <% user.addresses.forEach((addr, idx) => { %>
                            <div class="flex items-start gap-3 p-3 border rounded-xl hover:border-emerald-500 <%= idx === 0 ? 'border-emerald-500 bg-emerald-50' : 'border-gray-200' %>">
                                <input type="radio" id="addr-<%= idx %>" name="selectedAddress" value="<%= addr.address %>, <%= addr.city %>, <%= addr.state %> <%= addr.zip %> (Phone: <%= addr.phone || 'N/A' %>)" class="mt-1.5 text-emerald-600 focus:ring-emerald-500" <%= idx === 0 ? 'checked' : '' %>>
                                <label for="addr-<%= idx %>" class="flex-1 cursor-pointer">
                                    <p class="text-sm font-medium text-gray-900">Address <%= idx + 1 %></p>
                                    <p class="text-xs text-gray-600 mt-0.5"><%= addr.address %>, <%= addr.city %>, <%= addr.state %> <%= addr.zip %></p>
                                    <p class="text-xs font-semibold text-gray-500 mt-0.5"><i class="ri-phone-line"></i> <%= addr.phone || 'N/A' %></p>
                                </label>
                                <form action="/users/address/delete/<%= addr._id %>" method="POST">
                                    <button type="submit" class="text-red-400 hover:text-red-600 p-1 rounded-md hover:bg-red-50 transition"><i class="ri-delete-bin-line"></i></button>
                                </form>
                            </div>
                        <% }) %>
                    </div>
                <% } %>

                <form action="/users/address/add" method="POST" class="mt-4 border-t border-gray-100 pt-4">
                    <p class="text-sm font-semibold text-gray-900 mb-3">Add New Address</p>
                    <div class="grid grid-cols-2 gap-3">
                        <input type="text" name="address" placeholder="Street Address" class="col-span-2 text-sm rounded-lg border border-gray-200 px-3 py-2 outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500" required>
                        <input type="text" name="city" placeholder="City" class="col-span-1 text-sm rounded-lg border border-gray-200 px-3 py-2 outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500" required>
                        <input type="text" name="state" placeholder="State" class="col-span-1 text-sm rounded-lg border border-gray-200 px-3 py-2 outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500" required>
                        <input type="text" name="zip" placeholder="ZIP Code" class="col-span-1 text-sm rounded-lg border border-gray-200 px-3 py-2 outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500" required>
                        <input type="text" name="phone" placeholder="Mobile Number" class="col-span-1 text-sm rounded-lg border border-gray-200 px-3 py-2 outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500" required>
                        <button type="submit" class="col-span-2 bg-emerald-50 text-emerald-700 text-sm font-semibold rounded-lg hover:bg-emerald-100 transition py-2">Save Address</button>
                    </div>
                </form>
            </div>

            <!-- Bill Details -->
            <div class="bg-white p-4 rounded-2xl shadow-sm border border-gray-100">
                <div class="flex items-start justify-between gap-3">
                    <div>
                        <h2 class="text-lg font-semibold text-gray-900">Bill details</h2>
                        <p class="text-xs text-gray-500 mt-1">Taxes & charges included</p>
                    </div>
                    <span class="text-[11px] font-semibold text-gray-600 bg-gray-50 border border-gray-100 px-3 py-1 rounded-full">
                        INR
                    </span>
                </div>

                <div class="mt-4 space-y-3">
                    <div class="flex items-center justify-between text-sm">
                        <p class="text-gray-600">Items total</p>
                        <p class="text-gray-900 font-medium">₹<%= finalprice %></p>
                    </div>
                    <div class="flex items-center justify-between text-sm">
                        <p class="text-gray-600">Delivery charge</p>
                        <p class="text-gray-900 font-medium">₹30</p>
                    </div>
                    <div class="flex items-center justify-between text-sm">
                        <p class="text-gray-600">Handling charge</p>
                        <p class="text-gray-900 font-medium">₹4</p>
                    </div>

                    <div class="border-t border-gray-100 pt-3 flex items-end justify-between">
                        <p class="text-gray-900 font-bold text-base">Grand total</p>
                        <p class="text-gray-900 font-extrabold text-2xl">₹<%= finalprice + 34 %></p>
                    </div>
                </div>
            </div>

            <!-- Donation -->
            <div class="bg-white p-4 rounded-2xl shadow-sm border border-gray-100">
                <div class="flex items-start gap-3">
                    <div class="h-10 w-10 rounded-xl bg-emerald-50 border border-emerald-100 flex items-center justify-center overflow-hidden">
                        <img src="https://b.zmtcdn.com/data/fi_assets/9fbf0569f69bfef7d190c5b892ab0a521619355737.png"
                            alt="Feeding India" class="h-6 w-6 object-contain">
                    </div>
                    <div class="flex-1">
                        <div class="flex items-center justify-between gap-3">
                            <p class="font-semibold text-gray-900">Feeding India donation</p>
                            <span class="text-xs font-bold text-gray-900 bg-gray-50 border border-gray-100 px-3 py-1 rounded-full">
                                ₹1
                            </span>
                        </div>
                        <p class="text-xs text-gray-500 mt-1 leading-relaxed">
                            Working towards a malnutrition free India. Feeding India...
                            <span class="text-blue-500 font-semibold">read more</span>
                        </p>
                    </div>
                </div>
            </div>

            <!-- Delivery Instructions -->
            <div class="bg-white p-4 rounded-2xl shadow-sm border border-gray-100">
                <div class="flex items-start justify-between gap-3">
                    <div>
                        <h2 class="text-lg font-semibold text-gray-900">Delivery instructions</h2>
                        <p class="text-xs text-gray-500 mt-1">Choose how the delivery should happen</p>
                    </div>
                </div>

                <div class="mt-4 grid grid-cols-2 sm:grid-cols-4 gap-3">
                    <button type="button"
                        class="delivery-instruction-btn flex flex-col items-center justify-center py-3 bg-gray-50 border border-gray-100 rounded-2xl transition group">
                        <i class="ri-mic-line text-lg text-gray-700 group-[.active]:text-emerald-600 pointer-events-none"></i>
                        <p class="mt-1 text-xs font-semibold text-gray-700 group-[.active]:text-emerald-700 pointer-events-none">Record</p>
                    </button>
                    <button type="button"
                        class="delivery-instruction-btn flex flex-col items-center justify-center py-3 bg-gray-50 border border-gray-100 rounded-2xl transition group">
                        <i class="ri-prohibited-line text-lg text-gray-700 group-[.active]:text-emerald-600 pointer-events-none"></i>
                        <p class="mt-1 text-xs font-semibold text-gray-700 group-[.active]:text-emerald-700 pointer-events-none">Avoid calling</p>
                    </button>
                    <button type="button"
                        class="delivery-instruction-btn flex flex-col items-center justify-center py-3 bg-gray-50 border border-gray-100 rounded-2xl transition group">
                        <i class="ri-notification-off-line text-lg text-gray-700 group-[.active]:text-emerald-600 pointer-events-none"></i>
                        <p class="mt-1 text-xs font-semibold text-gray-700 group-[.active]:text-emerald-700 pointer-events-none">No bell</p>
                    </button>
                    <button type="button"
                        class="delivery-instruction-btn flex flex-col items-center justify-center py-3 bg-gray-50 border border-gray-100 rounded-2xl transition group">
                        <i class="ri-door-open-line text-lg text-gray-700 group-[.active]:text-emerald-600 pointer-events-none"></i>
                        <p class="mt-1 text-xs font-semibold text-gray-700 group-[.active]:text-emerald-700 pointer-events-none">Leave at door</p>
                    </button>
                </div>
            </div>


            <!-- Cancellation Policy -->
            <div class="bg-white p-4 rounded-2xl shadow-sm border border-gray-100 mb-10 mt-6">
                <div class="flex items-start gap-3">
                    <div class="h-10 w-10 rounded-xl bg-rose-50 border border-rose-100 flex items-center justify-center">
                        <i class="ri-close-circle-line text-rose-600 text-xl"></i>
                    </div>
                    <div class="flex-1">
                        <p class="text-sm font-semibold text-gray-900">Cancellation policy</p>
                        <p class="text-xs text-gray-600 mt-1 leading-relaxed">
                            Orders cannot be cancelled once packed for delivery. In case of unexpected delays, a refund will be
                            provided, if applicable.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Footer -->
            <div class="bg-white/95 backdrop-blur p-3 rounded-t-2xl shadow-[0_-4px_15px_rgba(15,23,42,0.16)] fixed bottom-0 inset-x-0 border-t border-gray-100">
                <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                    <div class="flex-1">
                        <div class="flex items-start justify-between gap-3">
                            <div>
                                <p class="text-xs font-semibold text-gray-500 uppercase">Delivering to</p>
                                <p id="footer-address-text" class="text-sm text-gray-800 mt-1">
                                    Please select an address above
                                </p>
                            </div>
                            <button type="button" onclick="document.getElementById('address-section').scrollIntoView({behavior: 'smooth'})" class="text-xs font-semibold text-emerald-700 hover:text-emerald-800 whitespace-nowrap">
                                Change
                            </button>
                        </div>
                    </div>

                    <div class="sm:w-[18rem] w-full">
                        <div class="flex items-start justify-between gap-4">
                            <div>
                                <p class="text-xs font-semibold text-gray-500 uppercase">Pay using</p>
                                <p class="text-sm text-gray-800 mt-1 flex items-center gap-2">
                                    <i class="ri-bank-card-line text-gray-500 text-base"></i>
                                    Paytm UPI
                                </p>
                            </div>
                            <div class="text-right">
                                <p class="text-xs font-semibold text-gray-500 uppercase">Total</p>
                                <p class="text-2xl font-extrabold text-gray-900 mt-1">₹<%= finalprice + 34 %></p>
                            </div>
                        </div>

                        <button class="paybtn mt-2 w-full bg-emerald-700 hover:bg-emerald-800 text-white px-4 py-2.5 rounded-xl font-semibold shadow-sm transition"
                            type="button">
                            Place Order
                        </button>
                    </div>
                </div>
            </div>
            <% } else { %>
                <div class="bg-white p-12 rounded-2xl shadow-sm border border-gray-100 flex flex-col items-center justify-center mt-10">
                    <div class="h-24 w-24 bg-emerald-50 rounded-full flex items-center justify-center mb-6">
                        <i class="ri-shopping-cart-2-line text-4xl text-emerald-600"></i>
                    </div>
                    <h2 class="text-xl font-bold text-gray-900">Your cart is empty</h2>
                    <p class="text-sm text-gray-500 mt-2 text-center max-w-xs">Looks like you haven't added anything to your cart yet.</p>
                    <a href="/" class="mt-8 inline-flex items-center justify-center px-8 py-3 bg-emerald-600 text-white font-semibold rounded-xl shadow-sm hover:bg-emerald-700 transition">
                        Start Shopping
                    </a>
                </div>
            <% } %>
        </div>

        <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"
            integrity="sha512-v2CJ7UaYy4JwqLDIrZUI/4hqeoQieOmAZNXBeQyjo21dadnwR+8ZaIJVT8EE2iyI61OV8e6M8PP2/4hpQINQ/g=="
            crossorigin="anonymous" referrerpolicy="no-referrer"></script>
            
        <script>
            const cartData = <%- JSON.stringify(cart) %>;
            
            // Dynamically update footer address
            const radios = document.querySelectorAll('input[name="selectedAddress"]');
            const footerAddress = document.getElementById('footer-address-text');
            
            function updateFooterAddress() {
                const selected = document.querySelector('input[name="selectedAddress"]:checked');
                if(selected && footerAddress) {
                    footerAddress.textContent = selected.value;
                }
            }
            
            radios.forEach(radio => {
                radio.addEventListener('change', updateFooterAddress);
            });
            updateFooterAddress();

            // Delivery Instructions JS
            const instructionBtns = document.querySelectorAll('.delivery-instruction-btn');
            instructionBtns.forEach(btn => {
                btn.addEventListener('click', function() {
                    this.classList.toggle('active');
                    this.classList.toggle('bg-emerald-50');
                    this.classList.toggle('border-emerald-200');
                    this.classList.toggle('bg-gray-50');
                    this.classList.toggle('border-gray-100');
                });
            });

            document.querySelector('.paybtn').onclick = function (e) {
                const selectedAddressRadio = document.querySelector('input[name="selectedAddress"]:checked');
                if (!selectedAddressRadio) {
                    alert("Please select or add a delivery address before placing your order!");
                    return;
                }
                const selectedAddress = selectedAddressRadio.value;

                console.log('Button clicked');
                axios.post('/payment/create/order', { amount: <%= finalprice + 34 %> })
                    .then(function (response) {
                        var options = {
                            "key": "<%= razorpayKeyId %>",
                            "amount": response.data.order.amount, // Amount in currency subunits. Default currency is INR.
                            "currency": response.data.order.currency,
                            "name": "BlinkIt",
                            "description": "Test Transaction",
                            "image": "https://example.com/your_logo",
                            "order_id": response.data.order.id,
                            "handler": function (payResponse) {
                                axios.post('/payment/api/payment/verify', {
                                    razorpay_order_id: payResponse.razorpay_order_id,
                                    razorpay_payment_id: payResponse.razorpay_payment_id,
                                    razorpay_signature: payResponse.razorpay_signature,
                                    amount: <%= finalprice + 34 %>,
                                    address: selectedAddress,
                                    cart: cartData
                                })
                                    .then(function (verifyRes) {
                                        if (verifyRes.data && verifyRes.data.success) {
                                            var oid = encodeURIComponent(payResponse.razorpay_order_id);
                                            window.location.href = '/order/success/' + oid;
                                        } else {
                                            alert(verifyRes.data && verifyRes.data.message ? verifyRes.data.message : 'Verification failed');
                                        }
                                    })
                                    .catch(function (error) {
                                        var msg = (error.response && error.response.data && error.response.data.message) || error.message;
                                        alert(msg || 'Could not verify payment');
                                    });
                            },
                            "prefill": {
                                "name": "Pradyumna kumar",
                                "email": "pradyumna@example.com",
                                "contact": "9000090000"
                            },
                            "notes": {
                                "address": "Razorpay Corporate Office"
                            },
                            "theme": {
                                "color": "#3399cc"
                            }
                        };
                        var rzp1 = new Razorpay(options);
                        rzp1.on('payment.failed', function (fail) {
                            var desc = (fail.error && fail.error.description) ? fail.error.description : 'Payment failed';
                            window.location.href = '/order/payment-failed?reason=' + encodeURIComponent(desc);
                        });
                        rzp1.open();
                        e.preventDefault();
                    })
                    .catch(function (error) {
                        console.error(error);
                    });
            };
        </script>
    </body>

    <%- include('./partials/footer'); %>