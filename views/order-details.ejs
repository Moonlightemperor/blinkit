<%- include('./partials/header'); %>

<body class="bg-gray-50">
    <header class="sticky top-0 z-[1000] bg-white/80 backdrop-blur border-b border-gray-100 flex items-center">
        <div class="max-w-7xl mx-auto px-4 py-3 w-full flex items-center justify-between">
            <div class="flex items-center gap-3">
                <a href="/" class="text-gray-600 hover:text-gray-800">
                    <i class="ri-arrow-left-line text-xl"></i>
                </a>
                <div>
                    <h1 class="text-sm sm:text-base font-semibold text-gray-900">Order Details</h1>
                    <p class="text-xs text-gray-500">Order #<%= order.orderID %></p>
                </div>
            </div>
            <div class="flex items-center gap-2">
                <span class="text-xs font-semibold px-2 py-1 rounded-full 
                    <% if(order.status === 'pending') { %>
                        bg-yellow-50 text-yellow-700 border border-yellow-100
                    <% } else if(order.status === 'confirmed') { %>
                        bg-blue-50 text-blue-700 border border-blue-100
                    <% } else if(order.status === 'shipped') { %>
                        bg-purple-50 text-purple-700 border border-purple-100
                    <% } else if(order.status === 'delivered') { %>
                        bg-green-50 text-green-700 border border-green-100
                    <% } else { %>
                        bg-red-50 text-red-700 border border-red-100
                    <% } %>
                ">
                    <%= order.status.charAt(0).toUpperCase() + order.status.slice(1) %>
                </span>
            </div>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 py-6 space-y-6">
        <!-- Delivery Information -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="p-4 border-b border-gray-100">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 flex items-center justify-center rounded-full bg-emerald-50">
                        <i class="ri-truck-line text-emerald-600 text-xl"></i>
                    </div>
                    <div>
                        <h2 class="text-base font-semibold text-gray-900">Delivery Information</h2>
                        <p class="text-xs text-gray-500">Estimated delivery: <%= Math.floor((Math.random()*20)+10) %> minutes</p>
                    </div>
                </div>
            </div>
            <div class="p-4">
                <div class="space-y-3">
                    <div class="flex items-start gap-3">
                        <i class="ri-map-pin-line text-gray-400 mt-0.5"></i>
                        <div class="flex-1">
                            <p class="text-sm font-medium text-gray-900">Delivery Address</p>
                            <p class="text-sm text-gray-600 mt-1"><%= order.address %></p>
                        </div>
                    </div>
                    <div class="flex items-start gap-3">
                        <i class="ri-time-line text-gray-400 mt-0.5"></i>
                        <div class="flex-1">
                            <p class="text-sm font-medium text-gray-900">Order Time</p>
                            <p class="text-sm text-gray-600 mt-1"><%= new Date(order.createdAt).toLocaleString() %></p>
                        </div>
                    </div>
                </div>
                

            </div>
        </div>

        <!-- Order Items -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="p-4 border-b border-gray-100">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 flex items-center justify-center rounded-full bg-blue-50">
                        <i class="ri-shopping-bag-line text-blue-600 text-xl"></i>
                    </div>
                    <div>
                        <h2 class="text-base font-semibold text-gray-900">Order Items</h2>
                        <p class="text-xs text-gray-500"><%= order.products.length %> item<%= order.products.length > 1 ? 's' : '' %></p>
                    </div>
                </div>
            </div>
            <div class="divide-y divide-gray-100">
                <% order.products.forEach(function(item) { %>
                <div class="p-4 flex items-center gap-4">
                    <div class="w-16 h-16 bg-gray-100 rounded-xl flex items-center justify-center">
                        <% if(item.product) { %>
                            <img src="/products/image/<%= item.product._id %>?v=1" alt="<%= item.product.name %>" class="w-full h-full object-cover rounded-xl bg-white p-0.5 border border-gray-100">
                        <% } else { %>
                            <i class="ri-image-line text-gray-400 text-xl"></i>
                        <% } %>
                    </div>
                    <div class="flex-1">
                        <p class="text-sm font-medium text-gray-900">
                            <%= item.product ? item.product.name : 'Product' %>
                        </p>
                        <p class="text-xs text-gray-500 mt-1">Quantity: <%= item.quantity %></p>
                    </div>
                    <div class="text-right">
                        <p class="text-sm font-semibold text-gray-900">
                            ₹<%= item.product ? (item.product.price * item.quantity) : '0' %>
                        </p>
                        <p class="text-xs text-gray-500">₹<%= item.product ? item.product.price : '0' %> each</p>
                    </div>
                </div>
                <% }); %>
            </div>
        </div>

        <!-- Price Breakdown -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="p-4 border-b border-gray-100">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 flex items-center justify-center rounded-full bg-purple-50">
                        <i class="ri-money-rupee-circle-line text-purple-600 text-xl"></i>
                    </div>
                    <h2 class="text-base font-semibold text-gray-900">Price Details</h2>
                </div>
            </div>
            <div class="p-4 space-y-3">
                <div class="flex justify-between items-center">
                    <p class="text-sm text-gray-600">Subtotal</p>
                    <p class="text-sm font-medium text-gray-900">₹<%= order.totalPrice %></p>
                </div>
                <div class="flex justify-between items-center">
                    <p class="text-sm text-gray-600">Delivery Fee</p>
                    <p class="text-sm font-medium text-gray-900">₹40</p>
                </div>
                <div class="flex justify-between items-center">
                    <p class="text-sm text-gray-600">Platform Fee</p>
                    <p class="text-sm font-medium text-gray-900">₹10</p>
                </div>
                <div class="pt-3 border-t border-gray-100">
                    <div class="flex justify-between items-center">
                        <p class="text-base font-semibold text-gray-900">Total Amount</p>
                        <p class="text-base font-bold text-emerald-600">₹<%= order.totalPrice + 50 %></p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="space-y-3 pb-6">
            <a href="/users/profile" class="w-full bg-emerald-600 hover:bg-emerald-700 text-white font-semibold px-4 py-3 rounded-xl transition text-sm flex items-center justify-center gap-2">
                <i class="ri-truck-line"></i>
                Track Order
            </a>
            <div class="grid grid-cols-2 gap-3">
                <a href="mailto:support@blinkit.com" class="bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium px-4 py-3 rounded-xl transition text-sm flex items-center justify-center gap-2">
                    <i class="ri-customer-service-line"></i>
                    Support
                </a>
                <button onclick="window.print()" class="bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium px-4 py-3 rounded-xl transition text-sm flex items-center justify-center gap-2">
                    <i class="ri-download-line"></i>
                    Invoice
                </button>
            </div>
        </div>
    </main>

    <script src="https://cdn.tailwindcss.com"></script>
</body>
</html>
