<%- include('./partials/header'); %>
<body class="bg-gradient-to-b from-emerald-50 via-white to-gray-100 min-h-screen font-sans antialiased">
  <div class="flex flex-col min-h-screen">
    <!-- Header -->
    <header class="sticky top-0 z-30 bg-white/80 backdrop-blur border-b border-gray-100">
      <div class="max-w-7xl mx-auto py-4 px-4 sm:px-6 lg:px-8 flex items-center justify-between gap-4">
        <div class="flex items-center gap-3">
          <a href="/admin/dashboard" class="h-10 w-10 rounded-xl bg-emerald-50 border border-emerald-100 flex items-center justify-center hover:bg-emerald-100 transition">
            <i class="ri-arrow-left-line text-emerald-700 text-xl"></i>
          </a>
          <div>
            <h1 class="text-lg sm:text-xl font-bold text-gray-900">Order Management</h1>
            <p class="text-xs text-gray-500 -mt-0.5">Track and update customer orders</p>
          </div>
        </div>

        <div class="flex items-center gap-2">
          <a href="/admin/logout"
            class="inline-flex items-center px-3 py-2 text-xs font-semibold rounded-full bg-emerald-600 text-white hover:bg-emerald-700 transition shadow-sm">
            Logout
          </a>
        </div>
      </div>
    </header>

    <main class="flex-1 overflow-y-auto">
      <div class="max-w-7xl mx-auto py-6 px-4 sm:px-6 lg:px-8 space-y-6">
        <% if (orders && orders.length > 0) { %>
            <div class="grid grid-cols-1 gap-6">
                <% orders.forEach(order => { %>
                    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 md:p-6">
                        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-6 border-b border-gray-100 pb-5">
                            <div>
                                <div class="flex items-center gap-3 mb-1">
                                    <h2 class="text-base font-bold text-gray-900 uppercase tracking-wide">Order #<%= order.orderID %></h2>
                                    <span class="inline-flex px-2.5 py-1 text-[11px] font-bold uppercase rounded-full <%= order.status === 'delivered' ? 'bg-emerald-100 text-emerald-800' : (order.status === 'dispatched' ? 'bg-amber-100 text-amber-800' : 'bg-blue-100 text-blue-800') %>">
                                        <%= order.status %>
                                    </span>
                                </div>
                                <p class="text-xs text-gray-500">
                                    <i class="ri-calendar-line mr-1"></i> <%= new Date(order.createdAt).toLocaleString('en-US', { dateStyle: 'medium', timeStyle: 'short' }) %>
                                </p>
                            </div>

                            <form action="/admin/orders/status/<%= order._id %>" method="POST" class="flex items-center gap-2 bg-gray-50 p-2 rounded-xl border border-gray-200">
                                <label class="text-xs font-semibold text-gray-600 ml-1">Update Status:</label>
                                <select name="status" class="text-sm font-medium bg-white border border-gray-200 rounded-lg px-3 py-1.5 outline-none focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 cursor-pointer">
                                    <option value="pending" <%= order.status === 'pending' ? 'selected' : '' %>>Pending</option>
                                    <option value="processing" <%= order.status === 'processing' ? 'selected' : '' %>>Processing</option>
                                    <option value="dispatched" <%= order.status === 'dispatched' ? 'selected' : '' %>>Dispatched</option>
                                    <option value="delivered" <%= order.status === 'delivered' ? 'selected' : '' %>>Delivered</option>
                                </select>
                                <button type="submit" class="bg-emerald-600 hover:bg-emerald-700 text-white text-xs font-semibold px-4 py-1.5 rounded-lg transition shadow-sm">
                                    Save
                                </button>
                            </form>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <!-- Customer Details -->
                            <div>
                                <h3 class="text-sm font-semibold text-gray-900 mb-3 border-b border-gray-100 pb-2">Customer & Delivery Info</h3>
                                <div class="space-y-2 text-sm">
                                    <p class="flex items-start gap-2">
                                        <i class="ri-user-3-line text-gray-400 mt-0.5"></i>
                                        <span class="font-medium text-gray-800"><%= order.user ? order.user.name : 'Unknown User' %></span>
                                    </p>
                                    <p class="flex items-start gap-2">
                                        <i class="ri-mail-line text-gray-400 mt-0.5"></i>
                                        <span class="text-gray-600"><%= order.user ? order.user.email : 'N/A' %></span>
                                    </p>
                                    <p class="flex items-start gap-2">
                                        <i class="ri-phone-line text-gray-400 mt-0.5"></i>
                                        <span class="text-gray-600"><%= order.user && order.user.phone ? order.user.phone : 'No phone provided' %></span>
                                    </p>
                                    <p class="flex items-start gap-2 mt-2 bg-gray-50 p-3 rounded-xl border border-gray-100">
                                        <i class="ri-map-pin-line text-emerald-600 mt-0.5"></i>
                                        <span class="text-gray-800 font-medium"><%= order.address %></span>
                                    </p>
                                </div>
                            </div>

                            <!-- Order Items -->
                            <div>
                                <div class="flex justify-between items-center mb-3 border-b border-gray-100 pb-2">
                                    <h3 class="text-sm font-semibold text-gray-900">Order Summary</h3>
                                    <span class="text-sm font-bold text-gray-900">Total: ₹<%= order.totalPrice %></span>
                                </div>
                                <div class="space-y-3 max-h-[200px] overflow-y-auto pr-2">
                                    <% order.products.forEach(item => { %>
                                        <% if (item.product) { %>
                                            <div class="flex items-center justify-between gap-3 bg-gray-50 p-2.5 rounded-xl border border-gray-100">
                                                <div class="flex items-center gap-3">
                                                    <img src="/products/image/<%= item.product._id %>?v=1" class="w-12 h-12 rounded-lg object-contain bg-white">
                                                    <div>
                                                        <p class="text-xs font-semibold text-gray-900 line-clamp-1"><%= item.product.name %></p>
                                                        <p class="text-[11px] text-gray-500 mt-0.5">₹<%= item.product.price %> x <%= item.quantity %></p>
                                                    </div>
                                                </div>
                                                <p class="text-sm font-bold text-gray-900">₹<%= Number(item.product.price) * Number(item.quantity) %></p>
                                            </div>
                                        <% } %>
                                    <% }) %>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-12 flex flex-col items-center justify-center min-h-[400px]">
                <div class="h-20 w-20 bg-gray-50 rounded-full flex items-center justify-center mb-4">
                    <i class="ri-inbox-2-line text-4xl text-gray-300"></i>
                </div>
                <h3 class="text-lg font-bold text-gray-900">No orders yet</h3>
                <p class="text-sm text-gray-500 mt-1 max-w-sm text-center">There are currently no customer orders in the database. When someone places an order, it will appear here.</p>
            </div>
        <% } %>
      </div>
    </main>
  </div>
</body>
<%- include('./partials/footer'); %>
